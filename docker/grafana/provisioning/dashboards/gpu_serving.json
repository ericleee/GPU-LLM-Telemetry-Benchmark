{
  "id": null,
  "uid": "gpu-serving",
  "title": "GPU Observability & Inference Serving",
  "tags": ["gpu", "inference", "telemetry"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GPU Temp",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 83 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "gpu_temperature_celsius", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU Power",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 140 },
            { "color": "red", "value": 165 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "gpu_power_watts", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GPU Utilization",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 50 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "gpu_utilization_percent", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p99 Latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 4 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 1,
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(inference_tokens_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Tokens/sec per Watt",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 3,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto"
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(inference_tokens_total[1m])) / avg(gpu_power_watts)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "GPU Power (W)  —  correlation row",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "gpu_power_watts", "legendFormat": "power (W)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GPU Temperature (°C)  —  throttle line at 83°C",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never", "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 83 }
          ] }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "gpu_temperature_celsius", "legendFormat": "temp (°C)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Serving Latency p50 / p99 (s)  —  correlation row",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum(rate(inference_request_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "GPU Utilization (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "gpu_utilization_percent", "legendFormat": "core", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "gpu_memory_utilization_percent", "legendFormat": "memory ctrl", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "VRAM Used / Total",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "gpu_memory_used_bytes", "legendFormat": "used", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "gpu_memory_total_bytes", "legendFormat": "total", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "GPU Clocks (MHz)  —  SM & Memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "gpu_clock_sm_mhz", "legendFormat": "SM clock", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "gpu_clock_mem_mhz", "legendFormat": "Mem clock", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(inference_requests_total[1m]))", "legendFormat": "requests/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Throughput (tokens/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(inference_tokens_total[1m]))", "legendFormat": "tokens/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Concurrency — In-flight & Queue Depth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "inference_inflight_requests", "legendFormat": "in-flight", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "inference_queue_depth", "legendFormat": "queued", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },

    {
      "id": 16,
      "type": "state-timeline",
      "title": "Throttle Reasons  (red = active)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80, "lineWidth": 0 },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "—", "index": 0 }, "1": { "text": "THROTTLING", "index": 1 } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true, "showValue": "never", "alignValue": "left", "rowHeight": 0.9,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        { "refId": "A", "expr": "gpu_throttle_reason", "legendFormat": "{{reason}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
